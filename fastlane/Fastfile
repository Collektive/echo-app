require 'base64'
require 'json'
require 'tmpdir'

ANDROID_PACKAGE_NAME = 'it.unibo.collektive.echo'

def parse_json_document(value)
  JSON.parse(value)
rescue JSON::ParserError, TypeError
  nil
end

def play_store_service_account?(parsed)
  parsed.is_a?(Hash) &&
    parsed['type'] == 'service_account' &&
    !parsed['client_email'].to_s.empty? &&
    !parsed['private_key'].to_s.empty?
end

def summarize_play_store_json_candidate(candidate)
  parsed = parse_json_document(candidate)

  case parsed
  when Hash
    keys = parsed.keys.map(&:to_s).sort
    missing_requirements = []
    missing_requirements << 'type=service_account' unless parsed['type'] == 'service_account'
    missing_requirements << 'client_email' if parsed['client_email'].to_s.empty?
    missing_requirements << 'private_key' if parsed['private_key'].to_s.empty?

    summary = "JSON object keys: #{keys.first(12).join(', ')}"
    summary += ', ...' if keys.length > 12
    summary += "; missing #{missing_requirements.join(', ')}" unless missing_requirements.empty?
    if parsed.key?('web') || parsed.key?('installed')
      summary += '; looks like OAuth client credentials, not a service account key'
    end
    summary
  when String
    'JSON string wrapper'
  when Array
    'JSON array'
  when NilClass
    'not JSON'
  else
    "JSON #{parsed.class}"
  end
end

def add_play_store_json_candidate(candidates, value)
  candidate = value.to_s.strip
  candidate = candidate.sub(/\A(?:export\s+)?PLAY_STORE_JSON_KEY(?:_DATA)?\s*=\s*/, '').strip

  variants = [candidate]
  if (candidate.start_with?('"') && candidate.end_with?('"')) ||
     (candidate.start_with?("'") && candidate.end_with?("'"))
    variants << candidate[1...-1].strip
  end

  variants.each do |variant|
    candidates << variant unless variant.empty? || candidates.include?(variant)
  end
end

def base64_decode_play_store_json_candidate(candidate)
  compact = candidate.to_s.gsub(/\s+/, '')
  return nil if compact.empty?

  padded = compact + ('=' * ((4 - compact.length % 4) % 4))

  [compact, padded].uniq.each do |value|
    begin
      return Base64.strict_decode64(value)
    rescue ArgumentError
      begin
        return Base64.urlsafe_decode64(value)
      rescue ArgumentError
        nil
      end
    end
  end

  nil
end

def normalize_play_store_json(raw_value)
  candidates = []
  summaries = []
  add_play_store_json_candidate(candidates, raw_value)

  candidates.each do |candidate|
    parsed = parse_json_document(candidate)
    return JSON.generate(parsed) if play_store_service_account?(parsed)
    summaries << summarize_play_store_json_candidate(candidate)

    if parsed.is_a?(String)
      add_play_store_json_candidate(candidates, parsed)
    elsif parsed.is_a?(Hash)
      %w[PLAY_STORE_JSON_KEY PLAY_STORE_JSON_KEY_DATA json_key_data json_key].each do |key|
        add_play_store_json_candidate(candidates, parsed[key]) if parsed.key?(key)
      end
    end

    add_play_store_json_candidate(candidates, base64_decode_play_store_json_candidate(candidate))
  end

  FastlaneCore::UI.user_error!(
    "PLAY_STORE_JSON_KEY / PLAY_STORE_JSON_KEY_DATA must contain the Google Play service account JSON or its base64-encoded contents. " \
    "Safe parse summary: #{summaries.uniq.first(5).join(' | ')}"
  )
end

def write_play_store_json_key(raw_value)
  key_path = File.join(Dir.tmpdir, "echo-play-store-key-#{Process.pid}.json")
  File.write(key_path, normalize_play_store_json(raw_value) + "\n")
  File.chmod(0o600, key_path)
  key_path
end

def play_store_credentials_options
  key_path = ENV['PLAY_STORE_JSON_KEY_PATH'].to_s.strip
  return { json_key: key_path } unless key_path.empty?

  raw_key = ENV['PLAY_STORE_JSON_KEY_DATA'] || ENV['PLAY_STORE_JSON_KEY']
  if raw_key.to_s.strip.empty?
    FastlaneCore::UI.user_error!(
      "Missing Play Store credentials. Set PLAY_STORE_JSON_KEY_PATH or provide PLAY_STORE_JSON_KEY / PLAY_STORE_JSON_KEY_DATA."
    )
  end

  { json_key: write_play_store_json_key(raw_key) }
end

platform :android do
  lane :lint do
    gradle(
      task: "ktlintCheck",
      project_dir: "./"
    )
  end

  lane :build do
    gradle(
      task: "composeApp:assembleDebug",
      project_dir: "./"
    )
  end

  lane :release do
    # Build both release artifacts in one Gradle invocation to reduce startup overhead in CI
    gradle(
      tasks: ["composeApp:assembleRelease", "composeApp:bundleRelease"],
      project_dir: "./"
    )
  end

  lane :deploy do |options|
    target_track = options[:track] || 'internal' # ['internal', 'production', 'beta', 'alpha']

    upload_to_play_store(
      track: target_track,
      package_name: ANDROID_PACKAGE_NAME,
      aab: 'composeApp/build/outputs/bundle/release/composeApp-release.aab',
      **play_store_credentials_options
    )
  end
end

platform :ios do

  lane :build do
    gradle(
      task: "composeApp:linkDebugFrameworkIosArm64",
      project_dir: "./"
    )
  end

  lane :release do
    gradle(
      task: "composeApp:linkReleaseFrameworkIosArm64",
      project_dir: "./"
    )
    build_app(
      project: "./iosApp/iosApp.xcodeproj",
      scheme: "iosApp",
      configuration: "Release",
      destination: "generic/platform=iOS",
      allowProvisioningUpdates: true
    )
  end

end
